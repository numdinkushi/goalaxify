# Goalaxify environment variables

# --- Google OAuth / NextAuth (apps/web) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# --- Convex ---
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-name.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment-name.convex.site
CONVEX_DEPLOY_KEY=

# --- Vapi ---
NEXT_PUBLIC_VAPI_ENABLED=true
NEXT_PUBLIC_VAPI_WEBTOKEN=
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
VAPI_ASSISTANT_ID=
NEXT_PUBLIC_VAPI_ASSISTANT_ID=
NEXT_PUBLIC_VAPI_BOOTH_ASSISTANT_ID=
# Optional — must match your Vapi assistant's LLM if calls fail with provider errors
NEXT_PUBLIC_VAPI_MODEL_PROVIDER=openai
NEXT_PUBLIC_VAPI_MODEL_NAME=gpt-4.1

# --- Data source: mock | txline | convex ---
NEXT_PUBLIC_DATA_SOURCE=mock

# --- Cloudinary (server-side avatar uploads — apps/web) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# --- Solana / TxLINE setup (packages/txline-sdk) ---
# Change only this to switch active runtime network.
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta

# Backward-compatible generic wallet secret for the active network.
SOLANA_DEVNET_WALLET_SECRET=

# Preferred network-scoped wallet secrets.
SOLANA_WALLET_SECRET_DEVNET=
SOLANA_WALLET_SECRET_MAINNET=

# Populated after `npm run txline:setup`
TXLINE_GUEST_JWT=
TXLINE_API_TOKEN=
TXLINE_SUBSCRIPTION_TX_SIG=

# Preferred network-scoped TxLINE credentials.
TXLINE_GUEST_JWT_DEVNET=
TXLINE_GUEST_JWT_MAINNET=
TXLINE_API_TOKEN_DEVNET=
TXLINE_API_TOKEN_MAINNET=
TXLINE_SUBSCRIPTION_TX_SIG_DEVNET=
TXLINE_SUBSCRIPTION_TX_SIG_MAINNET=

# --- WSC Sports BlazeFeed (live goal clips — server-only) ---
# Request BlazeFeed API token from your WSC Sports account manager.
# Docs: https://dev.wsc-sports.com/docs/blazefeed-api-v1.md
WSC_BLAZEFEED_API_KEY=
# Optional label expression filter, e.g. world-cup-live
WSC_LABELS_FILTER=

# --- Solana RPC / program ---
# Devnet can use the public RPC. Mainnet browser staking needs a provider URL (Helius, QuickNode, etc.).
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
NEXT_PUBLIC_SOLANA_RPC_URL_DEVNET=https://api.devnet.solana.com
# Example: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
NEXT_PUBLIC_SOLANA_RPC_URL_MAINNET=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_PROGRAM_ID_DEVNET=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
NEXT_PUBLIC_SOLANA_PROGRAM_ID_MAINNET=9ExbZjAapQww1vfcisDmrngPinHTEfpjYRWMunJgcKaA

# --- Pool authority (populated by `npm run pool:setup`) ---
# Public: used by client for SOL staking + checklist
NEXT_PUBLIC_POOL_AUTHORITY_PUBKEY=
NEXT_PUBLIC_POOL_AUTHORITY_PUBKEY_DEVNET=
NEXT_PUBLIC_POOL_AUTHORITY_PUBKEY_MAINNET=
# Server-only: signs winner payout transfers (never expose to client)
POOL_AUTHORITY_PUBKEY=
POOL_AUTHORITY_PUBKEY_DEVNET=
POOL_AUTHORITY_PUBKEY_MAINNET=
POOL_AUTHORITY_SECRET=
POOL_AUTHORITY_SECRET_DEVNET=
POOL_AUTHORITY_SECRET_MAINNET=
SETTLEMENT_CRON_SECRET=
