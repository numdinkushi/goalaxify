{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "paths": {
      "@tx-on-chain/*": ["../../vendor/tx-on-chain/*"]
    }
  },
  "include": ["src", "../../vendor/tx-on-chain/types"]
}
